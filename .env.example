# ── Required ──────────────────────────────────────────────────────────────
# Your Google AI Studio API key
# Get one free at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────
# Maximum allowed upload file size in megabytes (default: 5)
MAX_FILE_SIZE_MB=5

# Comma-separated list of allowed CORS origins.
# Use "*" for local dev; set specific origins in production.
# Example: ALLOWED_ORIGINS=https://myapp.com,https://app.myapp.com
ALLOWED_ORIGINS=*
